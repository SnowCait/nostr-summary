{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "nostr-summary",
	"main": "src/index.ts",
	"compatibility_date": "2025-10-08",
	"observability": {
		"enabled": true,
		"logs": {
			"invocation_logs": false,
		},
	},
	"triggers": {
		"crons": ["0 * * * *"],
	},
	"kv_namespaces": [
		{
			"binding": "KV",
			"id": "%KV_ID%",
		},
	],
	"keep_vars": true,
}
